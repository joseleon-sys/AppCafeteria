# Copia este archivo a ".env" y completa los valores reales solo en local/hosting.
# No escribas secretos reales en este archivo.

NODE_ENV=
PORT=
# Origen permitido para CORS. En desarrollo, si queda vacio, se permiten localhost:5173/4173.
# En produccion debe apuntar al frontend real. Puede contener varios origenes separados por coma.
FRONTEND_URL=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Compatibilidad con nombres anteriores, si el despliegue aun los usa:
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL_DAYS=30

STRIPE_SECRET_KEY=
# Solo para desarrollo local. No usar en produccion ni en hosting.
DEV_BYPASS_STRIPE_PAYMENT=

FIREBASE_SERVICE_ACCOUNT_JSON=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ENABLED=

LOG_LEVEL=
LOGSTASH_TCP_URL=
